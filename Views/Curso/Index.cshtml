@model List<PlataformaCursosOnline.Models.ICurso>
@{
    ViewData["Title"] = "Cursos";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var tipoAtivo = ViewBag.Tipo as string;
    var busca = ViewBag.Busca as string;
}

<div class="page-header">
    <h1>Catálogo de Cursos</h1>
    <p>@Model.Count curso(s) encontrado(s)</p>
</div>

<form method="get" action="/Curso">
    <div class="filter-bar">
        <input type="text" name="busca" value="@busca" placeholder="🔍 Buscar curso..." />
        <button type="submit" name="tipo" value="" class="filter-btn @(tipoAtivo == null ? "active" : "")">Todos</button>
        <button type="submit" name="tipo" value="Vídeo" class="filter-btn @(tipoAtivo == "Vídeo" ? "active" : "")">▶ Vídeo</button>
        <button type="submit" name="tipo" value="Ao Vivo" class="filter-btn @(tipoAtivo == "Ao Vivo" ? "active" : "")">🔴 Ao Vivo</button>
    </div>
</form>

<div class="section" style="padding-top:0">
    @if (!Model.Any())
    {
        <div class="empty-state">
            <span class="icon">🔍</span>
            <h3>Nenhum curso encontrado</h3>
            <p>Tente ajustar os filtros ou a busca.</p>
        </div>
    }
    else
    {
        <div class="grid-3">
            @foreach (var c in Model)
            {
                <a class="card" asp-controller="Curso" asp-action="Detalhes" asp-route-id="@c.GetId()">
                    <span class="card-tipo @(c.GetTipo() == "Ao Vivo" ? "live" : "video")">
                        @(c.GetTipo() == "Ao Vivo" ? "🔴 Ao Vivo" : "▶ Vídeo")
                    </span>
                    <div class="card-nome">@c.GetNome()</div>
                    <div class="card-meta">
                        <span>⏱ @c.GetCargaHoraria()h</span>
                    </div>
                </a>
            }
        </div>
    }
</div>
